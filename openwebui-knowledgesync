function listKnowledgeBases() {
    httpRequest('GET', '/api/v1/knowledge/')
        .then(json => {
            const items = Array.isArray(json) ? json : (json.items || []);
            const simplified = items.map(kb => ({
                id: kb.id,
                name: kb.name,
                description: kb.description
            }));
            console.log(JSON.stringify(simplified, null, 2));
        })
        .catch(err => console.error('Request error:', err.message));
}

function listFiles() {
    httpRequest('GET', '/api/v1/files/')
        .then(json => console.log(JSON.stringify(json, null, 2)))
        .catch(err => console.error('Request error:', err.message));
}

function listFilesInKnowledgeBase(id) {
    httpRequest('GET', `/api/v1/knowledge/${id}`)
        .then(json => console.log(JSON.stringify(json, null, 2)))
        .catch(err => console.error('Request error:', err.message));
}

async function syncKnowledgeBase(singleFile = null, dryRun = false) {
    try {
        if (dryRun) console.log('DRY RUN — no changes will be made.');
        if (singleFile) {
            console.log(`Starting single-file sync: ${singleFile}`);
        } else {
            console.log('Starting knowledge base synchronization...');
        }

        // 1. Get local files and their hashes
        let localFiles = getLocalFiles(process.cwd(), '', fileRegex);
        if (singleFile) {
            if (!localFiles.includes(singleFile)) {
                console.error(`File not found (or excluded by fileregex): ${singleFile}`);
                process.exit(1);
            }
            localFiles = [singleFile];
        }
        const localHashes = {};
        for (const filename of localFiles) {
            localHashes[filename] = fileHash(filename);
        }
        if (!singleFile) console.log(`Found ${localFiles.length} local files.`);

        // 2. Load local sync state: records the local hash at last successful sync.
        // This avoids relying on OpenWebUI's hash (which is computed differently via TextLoader).
        const statePath = path.join(process.cwd(), '.sync-state');
        let syncState = {};
        if (fs.existsSync(statePath)) {
            try {
                syncState = JSON.parse(fs.readFileSync(statePath, 'utf-8'));
            } catch (e) {
                console.warn('Warning: could not read .sync-state, starting fresh');
            }
        }

        // 3. Get current knowledge base state via paginated /api/v1/knowledge/{id}/files
        const kbFiles = [];
        {
            let page = 1;
            while (true) {
                const res = await httpRequest('GET', `/api/v1/knowledge/${knowledgeBaseId}/files?page=${page}`);
                const items = res.items || [];
                if (items.length === 0) break;
                kbFiles.push(...items);
                page++;
            }
        }
        console.log(`Knowledge base contains ${kbFiles.length} files.`);

        const kbFilenameSet = new Set();
        const kbFileById = new Map();
        for (const kbFile of kbFiles) {
            const filename = decodeFilename(kbFile.meta.name, kbdirId);
            if (filename !== null) {
                kbFilenameSet.add(filename);
                kbFileById.set(filename, kbFile);
            }
        }

        // On first run (no state), seed state from KB so we don't re-upload everything.
        let stateUpdated = false;
        if (!singleFile) {
            for (const filename of kbFilenameSet) {
                if (!(filename in syncState) && localHashes[filename]) {
                    syncState[filename] = localHashes[filename];
                    stateUpdated = true;
                }
            }
        }

        // 4. Delete files from KB that no longer exist locally
        if (singleFile) {
            if (debug) console.log('Skipping deletion step (single-file mode).');
        }
        for (const filename of singleFile ? [] : kbFilenameSet) {
            if (!localFiles.includes(filename)) {
                const kbFile = kbFileById.get(filename);
                console.log(`${dryRun ? '[dry-run] Would delete' : 'Deleting'} file (no longer exists locally): ${filename}`);
                if (!dryRun) {
                    await removeFileFromKnowledgeBase(kbFile.id);
                    delete syncState[filename];
                    stateUpdated = true;
                }
            }
        }

        // 5. Upload and add new/changed files
        for (const filename of localFiles) {
            const localHash = localHashes[filename];
            const inKb = kbFilenameSet.has(filename);
            const stateHash = syncState[filename];
            const unchanged = inKb && stateHash === localHash;

            if (debug) {
                console.log(`\nProcessing: ${filename}`);
                console.log(`- inKb: ${inKb}, stateHash: ${stateHash || 'none'}, localHash: ${localHash}`);
            }

            if (unchanged) {
                if (debug) console.log(`Skipping (unchanged): ${filename}`);
                continue;
            }

            if (dryRun) {
                console.log(`[dry-run] Would ${!inKb ? 'upload (new)' : 'upload (changed)'}: ${filename}`);
                continue;
            }

            console.log(`Uploading file: ${filename}`);
            const uploadResult = await uploadFile(filename, kbdirId);

            if (!uploadResult || !uploadResult.id) {
                console.error(`Upload failed for ${filename}: No file ID in response`);
                console.error('Upload response:', JSON.stringify(uploadResult, null, 2));
                continue;
            }

            const fileId = uploadResult.id;
            console.log(`File uploaded successfully: ${filename} (${fileId})`);

            // Wait for server-side processing to complete before adding to KB
            if (uploadResult.hash === null) {
                console.log(`Waiting for file processing: ${filename}`);
                try {
                    await waitForFileProcessing(fileId);
                } catch (e) {
                    console.error(`Warning: ${e.message} — proceeding anyway`);
                }
            }

            // Add file to knowledge base
            console.log(`Adding file to knowledge base: ${filename}`);
            try {
                const addResult = await httpRequest('POST', `/api/v1/knowledge/${knowledgeBaseId}/file/add`, {
                    file_id: fileId
                });

                if (!addResult?.id) {
                    const detail = addResult?.detail || '';
                    if (detail.includes('Duplicate content')) {
                        console.warn(`Skipping ${filename}: duplicate content already exists in knowledge base`);
                        syncState[filename] = localHash;
                        stateUpdated = true;
                    } else {
                        console.error(`Failed to add file to knowledge base: ${filename}`);
                        console.error('Add response:', JSON.stringify(addResult, null, 2));
                        console.log(`Cleaning up uploaded file: ${filename} (${fileId})`);
                        await httpRequest('DELETE', `/api/v1/files/${fileId}`);
                    }
                    continue;
                }

                console.log(`File added to knowledge base successfully: ${filename}`);
                syncState[filename] = localHash;
                stateUpdated = true;

                // Periodically save state so interrupted syncs preserve progress
                if (stateUpdated && Object.keys(syncState).length % 50 === 0) {
                    fs.writeFileSync(statePath, JSON.stringify(syncState, null, 2));
                }
            } catch (err) {
                console.error(`Failed to add file to knowledge base: ${filename}`, err.message);
                console.log(`Cleaning up uploaded file: ${filename} (${fileId})`);
                await httpRequest('DELETE', `/api/v1/files/${fileId}`);
            }
        }

        if (!dryRun && stateUpdated) {
            fs.writeFileSync(statePath, JSON.stringify(syncState, null, 2));
        }

        console.log('Synchronization completed successfully!');
    } catch (error) {
        console.error('Synchronization failed:', error.message || error);
        process.exit(1);
    }
}

async function downloadFile(fileId) {
    try {
        await httpRequest('GET', `/api/v1/files/${fileId}/content`, null, null, false);
    } catch (error) {
        console.error(`Error downloading file ${fileId}:`, error.message);
        process.exit(1);
    }
}

// Main execution
const args = process.argv.slice(2);
if (args.length === 0) {
    usage();
    process.exit(1);
}
const command = args[0];

const configPath = path.join(process.cwd(), '.open-webui-knowledgesync');
if (!fs.existsSync(configPath)) {
    console.error('Configuration file not found:', configPath);
    process.exit(1);
}
const config = fs.readFileSync(configPath, 'utf8').trim().split('\n').reduce((acc, line) => {
    const [key, value] = line.split('=');
    acc[key.trim()] = value.trim();
    return acc;
}, {});

if (!config.open_webui_api_key) {
    console.error('Missing required configuration: open_webui_api_key');
    process.exit(1);
}

const knowledgeBaseId = config.knowledge_base_id;
const openWebuiApiKey = config.open_webui_api_key;
const openWebuiApiUrl = config.open_webui_api_url || 'http://localhost:3000';
const kbdirId = config.kbdir_id;
const fileRegex = config.fileregex; // Add fileregex from config

// call functions based on command
if (command === 'sync') {
    if (!knowledgeBaseId) {
        console.error('Knowledge base ID is required for sync command.');
        process.exit(1);
    }
    if (!kbdirId) {
        console.error('kbdir_id is required for sync command.');
        process.exit(1);
    }
    const dryRun = args.includes('--dry-run');
    const singleFile = args.slice(1).find(a => a !== '--dry-run') || null;
    syncKnowledgeBase(singleFile, dryRun);
} else if (command === 'listkb') {
    listKnowledgeBases();
} else if (command === 'listfiles') {
    listFiles();
} else if (command === 'listkbfiles') {
    if (!knowledgeBaseId) {
        console.error('Knowledge base ID is required for this command.');
        process.exit(1);
    }
    listFilesInKnowledgeBase(knowledgeBaseId);
} else if (command === 'download' && args.length === 2) {
    const fileId = args[1];
    if (!fileId) {
        console.error('File ID is required for download command.');
        process.exit(1);
    }
    downloadFile(fileId);
} else {
    usage();
    process.exit(1);
}
